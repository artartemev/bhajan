# Куда складывать загрузки и результаты
DATA_DIR=data

# Очередь: inline (в процессе API, для разработки) или rq (Redis)
QUEUE_BACKEND=inline
REDIS_URL=redis://localhost:6379/0

# Demucs-модель: htdemucs (4 стема) или htdemucs_6s (6 стемов, есть piano)
DEMUCS_MODEL=htdemucs
# Какой стем считать фисгармонью (для киртана обычно other; для htdemucs_6s — piano)
HARMONIUM_STEM=other

# Принудительный stub-режим (без ML), даже если библиотеки установлены
FORCE_STUB=0

# Лимит загрузки, МБ
MAX_UPLOAD_MB=100

# --- Тонкая настройка транскрипции/очистки нот (крутить под звук) ---
# Ноты короче этого выбрасываются как артефакт (секунды)
NOTE_MIN_DURATION=0.12
# Склейка нот одного тона с зазором меньше этого (секунды) — против дробления
NOTE_MERGE_GAP=0.10
# Порог зажигания ноты для фисгармони (доля от макс. CQT). Выше → меньше мусора
HARMONIUM_ONSET_THR=0.18
# Порог гашения (должен быть НИЖЕ onset — это и есть гистерезис)
HARMONIUM_OFFSET_THR=0.09
# Подавлять обертоны (+12/+19 полутонов над более громкой нотой)
HARMONIC_SUPPRESSION=1
# Максимум одновременных нот в кадре
MAX_POLYPHONY=6

# --- Forced alignment текста (faster-whisper) ---
# Размер модели: tiny / base / small / medium / large-v3 (баланс скорость/качество)
ASR_MODEL=small
# Язык: hi (хинди), sa (санскрит), bn (бенгали), en, ru, ... или auto
ASR_LANGUAGE=hi
# Устройство: auto / cpu / cuda
ASR_DEVICE=auto
# Тип вычислений: int8 (CPU, быстро) / float16 (GPU) / float32
ASR_COMPUTE_TYPE=int8
