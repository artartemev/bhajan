# Куда складывать загрузки и результаты
DATA_DIR=data

# Очередь: inline (в процессе API, для разработки) или rq (Redis)
QUEUE_BACKEND=inline
REDIS_URL=redis://localhost:6379/0

# Demucs-модель: htdemucs (4 стема) или htdemucs_6s (6 стемов, есть piano)
DEMUCS_MODEL=htdemucs
# Какой стем считать фисгармонью (для киртана обычно other; для htdemucs_6s — piano)
HARMONIUM_STEM=other

# Принудительный stub-режим (без ML), даже если библиотеки установлены
FORCE_STUB=0

# Лимит загрузки, МБ
MAX_UPLOAD_MB=100
